(cl-text tests.theorems.ehr_phenotyping
  (forall ((patient_id str) (encounter_id str)) (if (and (Patient patient_id (date 1970 1 1) unknown) (Encounter encounter_id patient_id (date 2024 1 1)) (Diagnosis encounter_id (Code ICD10 E11))) (DiabetesT2 patient_id null)))
  (forall ((patient_id str) (encounter_id str) (child_code str)) (if (and (Patient patient_id (date 1970 1 1) unknown) (Encounter encounter_id patient_id (date 2024 1 1)) (Diagnosis encounter_id (Code ICD10 child_code)) (IsA (Code ICD10 child_code) (Code ICD10 E11))) (DiabetesT2 patient_id null)))
  (forall ((patient_id str) (v float)) (if (and (Patient patient_id (date 1970 1 1) unknown) (LabResult patient_id (date 2024 1 1) (Code LOINC '4548-4') v '%') (ge v 6.5)) (DiabetesT2 patient_id 0.9)))
  (forall ((patient_id str)) (if (and (Patient patient_id (date 1970 1 1) unknown) (Medication patient_id (date 2024 1 1) (Code SNOMED '10370') null)) (DiabetesT2 patient_id 0.7)))
  (forall ((patient_id str) (encounter_id str)) (if (and (Patient patient_id (date 1970 1 1) unknown) (Encounter encounter_id patient_id (date 2024 1 1)) (Diagnosis encounter_id (Code ICD10 I10))) (Hypertension patient_id null)))
  (forall ((patient_id str) (systolic float) (diastolic float)) (if (and (Patient patient_id (date 1970 1 1) unknown) (LabResult patient_id (date 2024 1 1) (Code LOINC '8480-6') systolic mmHg) (LabResult patient_id (date 2024 1 1) (Code LOINC '8462-4') diastolic mmHg) (ge systolic 140) (ge diastolic 90)) (Hypertension patient_id 0.8)))
  (forall ((patient_id str) (encounter_id str)) (if (and (Patient patient_id (date 1970 1 1) unknown) (Encounter encounter_id patient_id (date 2024 1 1)) (Diagnosis encounter_id (Code ICD10 N18))) (CKD patient_id null null)))
  (forall ((patient_id str) (value float)) (if (and (Patient patient_id (date 1970 1 1) unknown) (LabResult patient_id (date 2024 1 1) (Code LOINC '62238-1') value 'mL/min/1.73m²')) (and (if (ge value 90) (CKD patient_id 1 0.5)) (if (not (ge value 90)) (and (if (ge value 60) (CKD patient_id 2 0.7)) (if (not (ge value 60)) (and (if (ge value 30) (CKD patient_id 3 0.9)) (if (not (ge value 30)) (and (if (ge value 15) (CKD patient_id 4 0.95)) (if (not (ge value 15)) (CKD patient_id 5 0.99)))))))))))
  (forall ((patient_id str)) (if (and (DiabetesT2 patient_id null) (Hypertension patient_id null)) (and (DiabetesT2 patient_id 1.0) (Hypertension patient_id 1.0))))
  (forall ((patient_id str) (confidence float)) (if (DiabetesT2 patient_id confidence) (Phenotype patient_id)))
  (forall ((patient_id str) (confidence float)) (if (Hypertension patient_id confidence) (Phenotype patient_id)))
  (forall ((patient_id str) (stage Optional) (confidence float)) (if (CKD patient_id stage confidence) (Phenotype patient_id)))
)