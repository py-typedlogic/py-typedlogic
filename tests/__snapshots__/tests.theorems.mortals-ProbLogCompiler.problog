person(_) :- fail.
mortal(_) :- fail.
ancestorof(_, _) :- fail.
mortal(X) :- person(X).
ancestorof(X, Y) :- ancestorof(X, Z), ancestorof(Z, Y).
typedlogic_constraint_violation :- ancestorof(X, Y), ancestorof(Y, X).
evidence(typedlogic_constraint_violation, false).
query(person(Name)).
query(mortal(Name)).
query(ancestorof(Ancestor, Descendant)).