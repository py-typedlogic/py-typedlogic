personwithage(_, _) :- fail.
adult(_) :- fail.
stageage(_, _) :- fail.
personwithage2(_, _) :- fail.
personwithaddress(_, _) :- fail.
adult(_Name) :- Age >= 18.
query(personwithage(Name, Age)).
query(adult(Name)).
query(stageage(Stage, Age)).
query(personwithage2(Name, Age_in_years)).
query(personwithaddress(Name, Zip_code)).